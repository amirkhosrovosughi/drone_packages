<sdf version="1.9">
  <model name="residental_road_pole_layout">
    <static>true</static>

    <!-- Poles distributed evenly along the sidewalk edge -->
    <include><uri>model://pole</uri><name>pole_1</name><pose>-3.00 4.34 0 0 0 1.5708</pose></include>
    <include><uri>model://pole</uri><name>pole_2</name><pose>0.00 4.34 0 0 0 1.5708</pose></include>
    <include><uri>model://pole</uri><name>pole_3</name><pose>3.00 4.34 0 0 0 1.5708</pose></include>
  </model>
</sdf>
